# =========================
# Core API Keys
# =========================
# Used by LangChain Groq clients (runtime + RAGAS tests)
GROQ_API_KEY=your_groq_api_key_here

# =========================
# PostgreSQL (Docker + Backend)
# =========================
# These are read by the postgres container during startup,****EXAMPLE
POSTGRES_DB=ecostream
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# These are read by backend/db/postgres.py when POSTGRES_URL is not set
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional single-string connection override
# Example: postgresql://postgres:postgres@db:5432/ecostream
POSTGRES_URL=

# =========================
# Service Endpoints
# =========================
YOLO_SERVICE_URL=http://vision:8001
CHROMA_PERSIST_DIR=/app/chroma_store

# =========================
# RAGAS Evaluation Controls (optional)
# =========================
RAGAS_JUDGE_MODEL=llama-3.3-70b-versatile
RAGAS_EVAL_CASES=15
RAGAS_QUESTION_SLEEP_SEC=45
RAGAS_RUN_TIMEOUT_SEC=600
RAGAS_RUN_MAX_RETRIES=4
RAGAS_LLM_CALL_SLEEP_SEC=45

# =========================
# Analyze Stress Test Controls (optional)
# =========================
ANALYZE_REQUEST_COUNT=50
ANALYZE_CONCURRENCY=50
ANALYZE_BASE_URL=http://localhost:8000/analyze
ANALYZE_IMAGE_PATH=image.png
ANALYZE_LAT=12.9716
ANALYZE_LON=77.5946
ANALYZE_CITY=Bangalore
